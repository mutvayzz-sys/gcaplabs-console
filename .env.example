# --- Supabase (identity source of truth; new API-key system, asymmetric JWT) ---
# From Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
# SUPABASE_ACCESS_TOKEN (for `npm run setup` only — never used at runtime)

# --- Agent37 Cloud control plane ---
# Server-only — shared managed-runtime API key used by the BFF. Never expose this to the browser.
AGENT37_API_KEY=agent37_api_key_here
AGENT37_TEMPLATE=agent37-hermes
AGENT37_INITIAL_CREDIT_MICROS=1000000

# --- Production only (local dev uses the browser's origin) ---
# Set to your deployed URL and re-run `npm run setup` so Supabase allow-lists
# it for auth email redirects.
# IMPORTANT: use the canonical host (the `www.` subdomain). The bare apex
# 308s to www. at the Vercel edge, and the cross-host follow-up drops
# Authorization headers under Node fetch — desktop clients see a 401
# "Sign in required" right after a successful login when this is the apex.
NEXT_PUBLIC_SITE_URL=https://www.console.gcaplabs.com

# --- Sentry (optional, for error tracking) ---
NEXT_PUBLIC_SENTRY_DSN=https://bbe29c...20ba@o4511656735670272.ingest.de.sentry.io/4511656742748240

# --- Stripe (NOT used during beta — beta is free) ---
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Composio (Integrations tab — connect Gmail/Slack/GitHub/etc to the managed agent) ---
# Server-only, from your Composio project settings. Never commit the real value —
# put it in .env.local (gitignored), not here.
COMPOSIO_API_KEY=