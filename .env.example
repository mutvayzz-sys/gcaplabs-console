# Get it from https://www.agent37.com/dashboard/cloud/api-keys
AGENT37_API_KEY=sk_live_replace_me

# Get it from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_replace_me

# Filled in by `npm run setup` — leave blank for a fresh free project, or paste an
# existing project's values (Project Settings -> API) to use that one instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Also filled in by `npm run setup`. Server-only (no NEXT_PUBLIC_ prefix) — never commit it
# or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Production only (local dev uses the browser's origin). Set your deployed URL and re-run
# `npm run setup` so Supabase allow-lists it for auth email redirects.
# NEXT_PUBLIC_SITE_URL=https://your-app.com
