# Copy to .env and fill in, then: set -a; source .env; set +a; ./register.sh

# Your Runtime Provider secret key. Mint one at https://docs.runtime-provider.example/dashboard/cloud.
# Keep it server-side; never ship it to a browser.
RUNTIME_API_KEY=sk_live_...

# The public image you published. Pin a tag (use the :<sha> the Action prints, or
# cut a release tag) — do not use :latest. Copy it from your repo's Packages page.
IMAGE_REF=ghcr.io/your-username/my-agent:<sha>

# Optional overrides:
# TEMPLATE_NAME=my-custom-agent
# RUNTIME_API_BASE_URL=https://api.runtime-provider.example
