# Copy to .env, fill in, then: set -a; source .env; set +a; node proxy.mjs

# Your OpenRouter key (server-side only, never commit). https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# A token you choose. the runtime presents this as `api_key`; put the SAME value in the
# instance's ~/.runtime/config.yaml custom_providers[].api_key.
PROXY_TOKEN=demo-proxy-token

# Optional: which OpenRouter model to serve.
UPSTREAM_MODEL=moonshotai/kimi-k2.7-code

# Optional: port (default 8787).
# PORT=8787
